# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=recipes

# JWT
JWT_SECRET=changeme-in-production-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
JWT_ISSUER=recipes-users-server

# LLM (for recipe generation fallback)
LLM_API_KEY=
LLM_BASE_URL=http://localhost:11435/v1
LLM_MODEL=qwen3:8b
LLM_PROMPT_PROFILE_DEFAULT=schema_first
LLM_PROMPT_PROFILE_COMPLEX=safety_complex_first
LLM_FALLBACK_DISABLED=false
LLM_FALLBACK_CANARY_PERCENT=100
LLM_STRICT_GENERATED_POLICY=none
LLM_ENABLE_SAFETY_REPAIR=true
LLM_DISABLE_THINKING_TAG=true
LLM_MAX_TOKENS=1600
LLM_TIMEOUT_SECONDS=180
LLM_REPAIR_TIMEOUT_SECONDS=90
LLM_PROMPT_VERSION=v1
LLM_ALERT_TIMEOUT_RATE_THRESHOLD=0.20
LLM_ALERT_SCHEMA_ERROR_RATE_THRESHOLD=0.15
LLM_ALERT_REPAIR_FAIL_RATE_THRESHOLD=0.50

# Judge model (optional, for metadata and secondary quality scoring)
LLM_JUDGE_ENABLED=false
LLM_JUDGE_BASE_URL=http://localhost:11435/v1
LLM_JUDGE_API_KEY=local-not-used
LLM_JUDGE_MODEL=mistral:latest
LLM_JUDGE_TIMEOUT_SECONDS=45
LLM_JUDGE_MAX_TOKENS=500
LLM_JUDGE_DISABLE_THINKING_TAG=true
LLM_JUDGE_MIN_CONFIDENCE=0.65

# Local Docker option (Ollama), for threshold testing:
# LLM_API_KEY=local-not-used
# LLM_BASE_URL=http://localhost:11435/v1
# LLM_MODEL=qwen3:8b
# LLM_PROMPT_PROFILE_DEFAULT=schema_first
# LLM_PROMPT_PROFILE_COMPLEX=safety_complex_first
# LLM_DISABLE_THINKING_TAG=true
# LLM_MAX_TOKENS=1600
# LLM_JUDGE_ENABLED=true
# LLM_JUDGE_MODEL=mistral:latest

# Cache
REDIS_URL=redis://localhost:6379
SEARCH_CACHE_TTL=6h
SEARCH_BLEND_MIN_GENERATED=1
SEARCH_BLEND_MAX_GENERATED_SHARE=0.40
SEARCH_BLEND_SEED=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# Request limits / throttling
MAX_BODY_BYTES=1048576
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40
IDEMPOTENCY_KEY_TTL=24h

# Environment
APP_ENV=development
INGREDIENT_POLICY_MODE=auto_create
INGREDIENT_CANDIDATE_SLA_HOURS=48

# Observability / alerting
ERROR_WEBHOOK_URL=

# Server Ports
RECIPES_SERVER_PORT=8081
USERS_SERVER_PORT=8082
FAVORITES_SERVER_PORT=8080
