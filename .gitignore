# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Environment and secrets
.env
.env.*
!.env.example
!.env.local.example
**/.env
**/.env.*
!**/.env.example

# Logs and runtime output
*.log
logs/
**/logs/
tmp/
temp/

# Build/cache artifacts
**/.next/
**/.next-cache/
**/.swc/
**/test-results/
**/playwright-report/
coverage/

# Node / frontend
node_modules/
**/node_modules/
web/.next/
web/out/
web/build/
web/coverage/

# Go / backend
server/bin/
server/coverage.out
**/*.test
server/lib/*

# Mobile
mobile/.expo/
mobile/.expo-shared/
mobile/dist/

# Docker and local infra
docker-data/
**/.docker/

# Python / tooling (if used by scripts)
__pycache__/
*.pyc

# LLM workspace local artifacts
llm/train/artifacts/*
!llm/train/artifacts/.gitkeep
llm/train/datasets/raw/
llm/train/datasets/processed/
llm/judge/tmp/
llm/evals/results/_scratch/

# Dataset workspace heavy source files (keep derived summaries/seeds tracked)
datasets/raw/server-lib/*.zip
datasets/raw/server-lib/*.json
datasets/raw/server-lib/*.csv
!datasets/raw/server-lib/.gitkeep

# Archives / backups
*.zip
*.tar
*.tar.gz
