# Next.js public env vars (prefix NEXT_PUBLIC_ for client-exposed vars)
# Option A (single API domain / gateway):
# NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# Option B (direct service URLs):
# NEXT_PUBLIC_API_RECIPES_URL=https://recipes-api.example.com
# NEXT_PUBLIC_API_USERS_URL=https://users-api.example.com
# NEXT_PUBLIC_API_FAVORITES_URL=https://favorites-api.example.com

# Local defaults (split ports)
NEXT_PUBLIC_API_URL=http://localhost
NEXT_PUBLIC_API_RECIPES_PORT=8081
NEXT_PUBLIC_API_USERS_PORT=8082
NEXT_PUBLIC_API_FAVORITES_PORT=8080
NEXT_PUBLIC_ERROR_WEBHOOK_URL=
