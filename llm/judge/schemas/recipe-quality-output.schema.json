{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RecipeQualityJudgeOutput",
  "type": "object",
  "required": [
    "overallScore",
    "coherenceScore",
    "safetyCompletenessScore",
    "techniqueScore",
    "confidence",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "overallScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "coherenceScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "safetyCompletenessScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "techniqueScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  }
}
