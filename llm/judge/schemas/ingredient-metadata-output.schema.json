{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IngredientMetadataJudgeOutput",
  "type": "object",
  "required": [
    "category",
    "aliasSuggestions",
    "allergenHints",
    "riskHints",
    "confidence",
    "evidence"
  ],
  "additionalProperties": false,
  "properties": {
    "category": {
      "type": "string",
      "minLength": 1
    },
    "aliasSuggestions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allergenHints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "riskHints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence": {
      "type": "string",
      "minLength": 1
    }
  }
}
